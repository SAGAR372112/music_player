#  --- PostgreSQL ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/music_player

# Set to True to print all SQL queries (useful for debugging)
DB_ECHO=False

# --- Media Storage ---
# Path where uploaded audio files are saved (relative to backend/ or absolute)
MEDIA_DIR=../media

# --- App ---
APP_TITLE=Music Player API
APP_VERSION=1.0.0